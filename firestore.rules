rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ════════════════════════════════════════════════════════════════
    // 🔑 HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin(userId) {
      return request.auth.token.admin == true;
    }
    
    function isUser(userId) {
      return request.auth.uid == userId;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    // ════════════════════════════════════════════════════════════════
    // 👥 USERS Collection → users/{uid}
    // ════════════════════════════════════════════════════════════════
    
    match /users/{uid} {
      // ✓ Users can read their own profile
      // ✓ Admins can read any profile
      allow read: if isSignedIn() && (isUser(uid) || isAdmin(request.auth.uid));
      
      // ✓ New user creates their profile at registration
      allow create: if isSignedIn() && isUser(uid);
      
      // ✓ Users can update their own profile
      // ✓ Admins can update any user profile (e.g., change plan)
      allow update: if isSignedIn() && (isUser(uid) || isAdmin(request.auth.uid))
        && (!resource.data.role || request.resource.data.role == resource.data.role);
      
      // ✓ Only admins can delete users
      allow delete: if isSignedIn() && isAdmin(request.auth.uid);
      
      // ════════════════════════════════════════════════════════════════
      // 📋 Subcollection: users/{uid}/pipeline/{prospectId}
      // Sales prospects tracked by each user
      // ════════════════════════════════════════════════════════════════
      
      match /pipeline/{prospectId} {
        // ✓ Users can read/write only their own pipeline
        allow read: if isSignedIn() && isUser(uid);
        allow create: if isSignedIn() && isUser(uid);
        allow update: if isSignedIn() && isUser(uid);
        allow delete: if isSignedIn() && isUser(uid);
      }
    }
    
    // ════════════════════════════════════════════════════════════════
    // 🏢 COMPANIES Collection → companies/{companyId}
    // Database of all companies (read by all, write by admins only)
    // ════════════════════════════════════════════════════════════════
    
    match /companies/{companyId} {
      // ✓ Any signed-in user can read companies (for search/prospect)
      allow read: if isSignedIn();
      
      // ✓ Only admins can create (import Excel)
      allow create: if isSignedIn() && isAdmin(request.auth.uid);
      
      // ✓ Only admins can update
      allow update: if isSignedIn() && isAdmin(request.auth.uid);
      
      // ✓ Only admins can delete
      allow delete: if isSignedIn() && isAdmin(request.auth.uid);
    }
    
    // ════════════════════════════════════════════════════════════════
    // ⚙️ CONFIG Collection → config/{key}
    // System configuration (read by all, write by admins)
    // ════════════════════════════════════════════════════════════════
    
    match /config/{key} {
      // ✓ Any signed-in user can read public config
      allow read: if isSignedIn() && 
        (resource.data.type == 'public' || isAdmin(request.auth.uid));
      
      // ✓ Only admins can write config
      allow write: if isSignedIn() && isAdmin(request.auth.uid);
    }
    
    // ════════════════════════════════════════════════════════════════
    // 📊 USAGE_LOGS Collection → usage_logs/{logId}
    // Audit trail of user actions (create by users, read by admins)
    // ════════════════════════════════════════════════════════════════
    
    match /usage_logs/{logId} {
      // ✓ Only admins can read usage logs
      allow read: if isSignedIn() && isAdmin(request.auth.uid);
      
      // ✓ Any signed-in user can create a log entry (for their own actions)
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      
      // ✓ Only admins can delete logs
      allow delete: if isSignedIn() && isAdmin(request.auth.uid);
    }
    
    // ════════════════════════════════════════════════════════════════
    // 💾 SAVED_SEARCHES Collection → saved_searches/{searchId}
    // User-specific saved searches (read/write by owner only)
    // ════════════════════════════════════════════════════════════════
    
    match /saved_searches/{searchId} {
      // ✓ Users can only read their own saved searches
      allow read: if isSignedIn() && isOwner(resource.data.uid);
      
      // ✓ Users can create only their own searches
      allow create: if isSignedIn() && isOwner(request.resource.data.uid);
      
      // ✓ Users can only update their own searches
      allow update: if isSignedIn() && isOwner(resource.data.uid);
      
      // ✓ Users can only delete their own searches
      allow delete: if isSignedIn() && isOwner(resource.data.uid);
    }
    
    // ════════════════════════════════════════════════════════════════
    // 📋 ADMIN_LOGS Collection → admin_logs/{logId}
    // Audit trail of admin actions (create/read/delete by admins only)
    // ════════════════════════════════════════════════════════════════
    
    match /admin_logs/{logId} {
      // ✓ Only admins can read admin logs
      allow read: if isSignedIn() && isAdmin(request.auth.uid);
      
      // ✓ Only admins can create admin logs
      allow create: if isSignedIn() && isAdmin(request.auth.uid);
      
      // ✓ Only admins can delete admin logs
      allow delete: if isSignedIn() && isAdmin(request.auth.uid);
    }
    
    // ════════════════════════════════════════════════════════════════
    // 🔒 DEFAULT DENY
    // All other paths are denied by default
    // ════════════════════════════════════════════════════════════════
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
