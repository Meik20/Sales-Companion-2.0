# Backend Environment Variables
# Copy to .env and fill with actual values
# NEVER commit this file with real values

# Node Environment
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# Firebase Admin Configuration
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=sales-companion-237
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sales-companion-237.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# CORS Configuration
WEB_ORIGIN=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# API Keys (optionnel)
GROQ_API_KEY=

# External Services
# If using external file storage
STORAGE_BUCKET=sales-companion-237.appspot.com

# Database
# Firestore is used - credentials via FIREBASE_*
FIRESTORE_EMULATOR_HOST=localhost:8080  # Development only

# Email Service (optionnel)
SENDGRID_API_KEY=
MAIL_FROM=noreply@salescompanion.cm

# Stripe (si payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public App Config & Payments (Mobile Money)
NEXT_PUBLIC_APP_URL=https://salescompanion2-0.com
NEXT_PUBLIC_PAYMENT_MTN_NUMBER=655886086
NEXT_PUBLIC_PAYMENT_MTN_NAME="MBAYE EYOUM IVAN KEVIN"
NEXT_PUBLIC_PAYMENT_ORANGE_NUMBER=655886086
NEXT_PUBLIC_PAYMENT_ORANGE_NAME="MBAYE EYOUM IVAN KEVIN"

# Session
SESSION_SECRET=your-random-secret-key-min-32-chars-long

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_AI=true
ENABLE_TEAM_MANAGEMENT=true
ENABLE_IMPORT=true

# Monitoring (optionnel)
SENTRY_DSN=
DATADOG_API_KEY=

# Development
DEBUG=false
PRETTY_LOGS=true
