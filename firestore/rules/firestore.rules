rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authUid() {
      return request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        currentUserDoc().role == 'admin'
      );
    }

    function currentUserDoc() {
      let userDoc = get(/databases/$(database)/documents/users/$(authUid())).data;
      return userDoc != null ? userDoc : {};
    }

    function isManager() {
      return isSignedIn() && (
        request.auth.token.role == 'manager' ||
        currentUserDoc().role == 'manager'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && authUid() == userId;
    }

    function isManagedUser(resourceManagerUid) {
      return isManager() && resourceManagerUid == authUid();
    }

    match /users/{uid} {
      allow read: if isAdmin()
        || isOwner(uid)
        || (isManager() && resource.data.managerUid == authUid());

      allow create: if isAdmin() || (
        isOwner(uid) 
        && request.resource.data.get('role', '') != 'admin'
        && request.resource.data.get('plan', 'free') == 'free'
        && request.resource.data.get('dailyLimit', 10) <= 10
      );

      allow update: if isAdmin()
        || (isOwner(uid) 
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['role', 'plan', 'dailyLimit', 'activated', 'managerUid', 'managerEmail'])
           );

      allow delete: if isAdmin();
    }

    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    function isSupportAgent() {
      return isSignedIn() && (
        request.auth.token.role == 'support_agent' ||
        currentUserDoc().role == 'support_agent'
      );
    }

    match /pipeline/{pipelineId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == authUid())
        || isManagedUser(resource.data.managerUid)
        || (isSupportAgent() 
            && (resource.data.status == 'conclue' || resource.data.status == 'conclusion')
            && (resource.data.managerUid == currentUserDoc().managerUid 
                || (currentUserDoc().linkedManagerUids != null && resource.data.managerUid in currentUserDoc().linkedManagerUids))
           );

      allow create: if isSignedIn()
        && request.resource.data.userId == authUid()
        && (
          request.resource.data.managerUid == authUid()
          || request.resource.data.managerUid == currentUserDoc().managerUid
          || request.resource.data.managerUid == null
        );

      allow update: if isAdmin()
        || (isSignedIn() && resource.data.userId == authUid() && request.resource.data.userId == authUid())
        || (isManagedUser(resource.data.managerUid) && request.resource.data.userId == resource.data.userId);
        
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == authUid())
        || isManagedUser(resource.data.managerUid);
    }

    match /saved_searches/{savedSearchId} {
      allow read: if isSignedIn() && resource.data.userId == authUid();
      allow create: if isSignedIn() && request.resource.data.userId == authUid();
      allow update: if isSignedIn() && resource.data.userId == authUid() && request.resource.data.userId == authUid();
      allow delete: if isSignedIn() && resource.data.userId == authUid();
    }

    match /support_threads/{threadId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == authUid());
      allow create: if isSignedIn() && request.resource.data.userId == authUid();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == authUid() && request.resource.data.userId == authUid());

      match /messages/{messageId} {
        allow read: if isAdmin() || (
          isSignedIn() &&
          get(/databases/$(database)/documents/support_threads/$(threadId)).data.userId == authUid()
        );

        allow create: if isAdmin() || (
          isSignedIn() &&
          get(/databases/$(database)/documents/support_threads/$(threadId)).data.userId == authUid()
        );
      }
    }

    match /team_accesses/{accessId} {
      // Désormais géré uniquement via Firebase Admin SDK sur le backend
      allow get: if false;

      allow read: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid());

      allow create: if isAdmin()
        || (
          isManager()
          && request.resource.data.managerUid == authUid()
          && (request.resource.data.role == 'member' || request.resource.data.role == 'support_agent')
        );

      allow update: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid());

      allow delete: if isAdmin();
    }

    match /team_assignments/{assignmentId} {
      allow read: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid());

      allow create: if isAdmin()
        || (
          isManager()
          && request.resource.data.managerUid == authUid()
        );

      allow update: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid());

      allow delete: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid());
    }

    match /assignments/{assignmentId} {
      allow read: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid())
        || (isSignedIn() && resource.data.assigneeUid == authUid());

      allow create: if isAdmin()
        || (
          isManager()
          && request.resource.data.managerUid == authUid()
        );

      allow update: if isAdmin()
        || (
          isManager()
          && resource.data.managerUid == authUid()
        )
        || (
          isSignedIn()
          && resource.data.assigneeUid == authUid()
        );

      allow delete: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid());
    }

    match /app_config/{key} {
      allow read, write: if isAdmin();
    }

    match /usage_logs/{logId} {
      allow create: if isSignedIn() && request.resource.data.userId == authUid();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /import_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /adminNotifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    // ── CRM Collections ─────────────────────────────────────────────────────

    match /customer_calls/{callId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.agentUid == authUid())
        || (isManager() && resource.data.managerUid == authUid())
        || isSupportAgent();
      allow create: if isSignedIn()
        && (isSupportAgent() || isManager() || isAdmin())
        && request.resource.data.agentUid == authUid();
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.agentUid == authUid());
    }

    match /customer_tickets/{ticketId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.agentUid == authUid())
        || (isManager() && resource.data.managerUid == authUid())
        || isSupportAgent();
      allow create: if isSignedIn()
        && (isSupportAgent() || isManager() || isAdmin())
        && request.resource.data.agentUid == authUid();
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.agentUid == authUid())
        || (isManager() && resource.data.managerUid == authUid());
      allow delete: if isAdmin();
    }

    match /support_agent_links/{linkId} {
      allow read: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid())
        || (isSupportAgent() && resource.data.agentUid == authUid());
      allow create: if isManager()
        && request.resource.data.managerUid == authUid()
        && request.resource.data.status == 'active';
      allow update: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid());
      allow delete: if isAdmin()
        || (isManager() && resource.data.managerUid == authUid());
    }
  }
}