{
  "name": "sales-companion",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "generate:pwa-icons": "node scripts/generate-pwa-icons.js",
    "dev:web": "npm run generate:pwa-icons && npm --workspace apps/web run dev",
    "dev:server": "npm --workspace apps/server run dev",
    "build:web": "npm run generate:pwa-icons && npm --workspace apps/web run build",
    "build:server": "npm --workspace apps/server run build",
    "build:shared": "npm --workspace packages/shared run build",
    "build": "npm run build:shared && npm run build:web && npm run build:server",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "typecheck:server": "npm --workspace apps/server run typecheck",
    "typecheck:shared": "npm --workspace packages/shared run typecheck",
    "typecheck": "npm run typecheck:shared && npm run typecheck:web && npm run typecheck:server",
    "lint": "npm run lint:web && npm run lint:server",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:server": "npm --workspace apps/server run lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:web": "npm --workspace apps/web run test",
    "test:server": "npm --workspace apps/server run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
  "postcss": "^8.5.10",
  "uuid": "^14.0.0",
  "@babel/runtime": "^7.26.10",
  "path-to-regexp": "^8.0.0",
  "send": "^0.19.0",
  "cookie": "^0.7.0"
}
}