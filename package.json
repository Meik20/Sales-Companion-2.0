{
  "name": "sales-companion",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "generate:pwa-icons": "node scripts/generate-pwa-icons.js",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "build:shared": "npm --workspace packages/shared run build",
    "build": "npm run build:shared && npm run build:web",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "typecheck:shared": "npm --workspace packages/shared run typecheck",
    "typecheck": "npm run typecheck:shared && npm run typecheck:web",
    "lint": "npm run lint:web",
    "lint:web": "npm --workspace apps/web run lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:web": "npm --workspace apps/web run test",
    "theme:lint": "designmd lint THEME.md",
    "theme:export": "designmd export --format tailwind THEME.md > tailwind.theme.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^14.0.0",
    "@babel/runtime": "^7.26.10",
    "path-to-regexp": "^8.0.0",
    "send": "^0.19.0",
    "cookie": "^0.7.0"
  },
  "dependencies": {
    "@google/design.md": "^0.1.1"
  }
}
